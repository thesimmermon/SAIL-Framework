            },
            {
              "type": "null"
            }
          ]
        },
        "Id": {
          "$ref": "#/$defs/IdString"
        }
      },
      "additionalProperties": false,
      "required": [
        "Kind",
        "Label",
        "SubDiagramId",
        "CharMapDiagramId",
        "CharacteristicMap",
        "Id"
