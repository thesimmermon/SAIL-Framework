{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://getsail.org/schemas/sail-architecture.schema.json",
  "title": "SAIL Architecture (.sail) JSON Schema",
  "description": "JSON Schema for Xebec/SAIL .sail files generated from the provided SailArchitecture C# data repository and example .sail file. Enums are serialized as integers by System.Text.Json in the current repository.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SuppressChangeNotifications",
    "Name",
    "Inventory",
    "StructuralContextDiagram",
    "HierarchicalDiagrams",
    "BehavioralContextDiagram",
    "InteractionDiagrams",
    "CharacteristicMapDiagrams",
    "InterfaceDiagrams",
    "Notebook"
  ],
  "properties": {
    "SuppressChangeNotifications": {
      "type": "boolean"
    },
    "Name": {
      "type": "string"
    },
    "Inventory": {
      "$ref": "#/$defs/Inventory"
    },
    "StructuralContextDiagram": {
      "$ref": "#/$defs/DiagramPolymorphic"
    },
    "HierarchicalDiagrams": {
      "$ref": "#/$defs/DiagramDictionary"
    },
    "BehavioralContextDiagram": {
      "$ref": "#/$defs/DiagramPolymorphic"
    },
    "InteractionDiagrams": {
      "$ref": "#/$defs/DiagramDictionary"
    },
    "CharacteristicMapDiagrams": {
      "$ref": "#/$defs/DiagramDictionary"
    },
    "InterfaceDiagrams": {
      "$ref": "#/$defs/DiagramDictionary"
    },
    "Notebook": {
      "$ref": "#/$defs/ArchitectureNotebookData"
    }
  },
  "$defs": {
    "IdString": {
      "type": "string",
      "minLength": 1,
      "description": "SAIL/Xebec identifier. Usually a GUID string."
    },
    "GuidString": {
      "type": "string",
      "format": "uuid"
    },
    "ColorString": {
      "type": "string",
      "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
    },
    "DateTimeString": {
      "type": "string",
      "format": "date-time"
    },
    "NullableDateTimeString": {
      "anyOf": [
        {
          "$ref": "#/$defs/DateTimeString"
        },
        {
          "type": "null"
        }
      ]
    },
    "StructuralElementType": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "x-enumNames": [
        "BoundaryParticipant",
        "System",
        "Datastore",
        "ServiceUnit"
      ]
    },
    "InteractionKind": {
      "type": "integer",
      "enum": [
        0,
        1,
        2
      ],
      "x-enumNames": [
        "Simple",
        "Composite",
        "Process"
      ]
    },
    "DiagramType": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "x-enumNames": [
        "StructuralContext",
        "StructuralHierarchical",
        "BehavioralContext",
        "BehavioralInteraction",
        "BehavioralProcess",
        "IntrinsicCharacteristicMap",
        "Interface"
      ]
    },
    "DiagramElementEdge": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3,
        4
      ],
      "x-enumNames": [
        "None",
        "Top",
        "Bottom",
        "Left",
        "Right"
      ]
    },
    "DecisionStatus": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3,
        4
      ],
      "x-enumNames": [
        "Proposed",
        "Approved",
        "Rejected",
        "Deferred",
        "Implemented"
      ]
    },
    "TodoStatus": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3,
        4
      ],
      "x-enumNames": [
        "Open",
        "InProgress",
        "Completed",
        "OnHold",
        "Cancelled"
      ]
    },
    "TodoPriority": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "x-enumNames": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    "AssumptionType": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3,
        4
      ],
      "x-enumNames": [
        "Technical",
        "Business",
        "Resource",
        "Schedule",
        "Other"
      ]
    },
    "RiskImpact": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "x-enumNames": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    "RiskStatus": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "x-enumNames": [
        "Active",
        "Mitigated",
        "Accepted",
        "Closed"
      ]
    },
    "ReferenceType": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3,
        4
      ],
      "x-enumNames": [
        "Standard",
        "External",
        "Internal",
        "Documentation",
        "Other"
      ]
    },
    "InventoryItemBase": {
      "type": "object",
      "properties": {
        "Id": {
          "$ref": "#/$defs/IdString"
        }
      },
      "additionalProperties": false,
      "required": [
        "Id"
      ]
    },
    "Characteristic": {
      "type": "object",
      "properties": {
        "Name": {
          "type": "string"
        },
        "Characteristics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Characteristic"
          }
        },
        "Id": {
          "$ref": "#/$defs/IdString"
        }
      },
      "additionalProperties": false,
      "required": [
        "Name",
        "Characteristics",
        "Id"
      ]
    },
    "CharacteristicCategory": {
      "type": "object",
      "properties": {
        "Name": {
          "type": "string"
        },
        "Characteristics": {
          "type": "array",
          "items": {
