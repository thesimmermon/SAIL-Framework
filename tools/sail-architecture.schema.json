      "additionalProperties": false,
      "required": [
        "Name",
        "Characteristics",
        "Id"
      ]
    },
    "CharacteristicMapDictionary": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/CharacteristicCategory"
      }
    },
    "StructuralElement": {
      "type": "object",
      "properties": {
        "Name": {
          "type": "string"
        },
        "ElementType": {
          "$ref": "#/$defs/StructuralElementType"
        },
        "SubType": {
          "type": "string"
        },
        "Description": {
          "type": "string"
        },
        "Refinement": {
          "type": "string"
        },
        "Identifier": {
          "type": "string"
        },
        "IsAbstract": {
          "type": "boolean"
        },
        "IsMultipleInstances": {
          "type": "boolean"
        },
        "IsStandIn": {
          "type": "boolean"
        },
        "RepresentedElementIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IdString"
          }
        },
        "SubDiagramId": {
          "type": [
            "string",
            "null"
          ]
        },
        "CharMapDiagramId": {
          "type": [
            "string",
            "null"
          ]
        },
        "CharacteristicMap": {
          "anyOf": [
            {
              "$ref": "#/$defs/CharacteristicMapDictionary"
            },
            {
              "type": "null"
            }
          ]
        },
        "Id": {
          "$ref": "#/$defs/IdString"
        }
      },
      "additionalProperties": false,
      "required": [
        "Name",
        "ElementType",
        "SubType",
        "Description",
        "Refinement",
        "Identifier",
        "IsAbstract",
        "IsMultipleInstances",
        "IsStandIn",
        "RepresentedElementIds",
        "SubDiagramId",
        "CharMapDiagramId",
        "CharacteristicMap",
        "Id"
      ]
    },
    "Interaction": {
      "type": "object",
      "properties": {
        "Kind": {
          "$ref": "#/$defs/InteractionKind"
        },
        "Label": {
          "type": "string"
        },
        "SubDiagramId": {
          "type": [
